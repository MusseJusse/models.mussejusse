---
import ModelExplorer from "../components/ModelExplorer";
import Base from "../layouts/Base.astro";
---

<Base title="models.dev catalog">
  <main class="min-h-screen bg-[#f7eee2] text-[#23170f]">
    <section class="mx-auto max-w-7xl px-5 py-5 lg:px-8">
      <header class="grid gap-6 py-8 lg:grid-cols-[minmax(0,1fr)_440px] lg:items-end">
        <div>
          <p class="text-sm font-black uppercase tracking-[.24em] text-[#be3b21]">models.dev catalog</p>
          <h1 class="font-display mt-3 max-w-4xl text-6xl font-black leading-[.86] sm:text-8xl">Model pricing and limits.</h1>
        </div>
        <ModelExplorer client:load />
      </header>
    </section>
  </main>
</Base>
